rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    function babyMembers(babyId) {
      return get(/databases/$(database)/documents/babies/$(babyId)).data.members;
    }

    function isMember(babyId) {
      return signedIn() && request.auth.uid in babyMembers(babyId);
    }

    match /babies/{babyId} {
      allow read: if signedIn() && request.auth.uid in resource.data.members;

      allow create: if signedIn()
        && request.resource.data.ownerUID == request.auth.uid
        && request.auth.uid in request.resource.data.members;

      // Existing members may update freely. A signed-in user joining via an
      // invite may add ONLY themselves to members (no removals, no other adds).
      allow update: if signedIn() && (
        request.auth.uid in resource.data.members ||
        (
          request.resource.data.members.hasAll(resource.data.members) &&
          request.resource.data.members.removeAll(resource.data.members) == [request.auth.uid]
        )
      );

      allow delete: if signedIn() && request.auth.uid == resource.data.ownerUID;

      match /entries/{entryId} {
        allow read, write: if isMember(babyId);
      }
    }

    match /invites/{code} {
      allow read: if signedIn();
      allow create: if signedIn() && request.resource.data.createdBy == request.auth.uid;
      allow delete: if signedIn();
    }
  }
}
